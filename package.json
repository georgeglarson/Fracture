{
  "name": "browserquest-ultra",
  "version": "1.0.0",
  "description": "BrowserQuest Ultra - HTML5 multiplayer RPG with Venice AI integration",
  "private": false,
  "scripts": {
    "watch:client": "webpack serve --env NODE_ENV=dev --config ./webpack.config.js --mode development",
    "watch:server": "tsx --watch  ./server/ts/main.ts",
    "build:client": "webpack --env NODE_ENV=prod --config ./webpack.config.js --mode production",
    "build:server": "tsc -p ./server",
    "start": "node dist/server/ts/main.js",
    "restart": "pkill -f 'node dist/server' 2>/dev/null; rm -f dist/.server.pid; sleep 1 && npm start",
    "stop": "pkill -f 'node dist/server' 2>/dev/null; rm -f dist/.server.pid",
    "dev": "concurrently \"npm run watch:client\" \"npm run watch:server\""
  },
  "dependencies": {
    "@venice-dev-tools/core": "^2025.11.6",
    "eventemitter3": "^5.0.1",
    "express": "^4.18.2",
    "jquery": "^3.7.1",
    "lodash": "3.10.1",
    "log": "^6.3.1",
    "sanitizer": "^0.1.3",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/jquery": "^3.5.32",
    "@types/lodash": "^3.10.1",
    "@types/node": "^24.10.1",
    "copy-webpack-plugin": "^11.0.0",
    "eslint": "^9.30.1",
    "html-webpack-plugin": "^5.5.3",
    "memcache": "^0.3.0",
    "ts-loader": "^9.4.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.2"
  }
}
