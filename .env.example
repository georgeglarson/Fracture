# Fracture Game Server - Environment Variables
# Copy this file to .env and fill in values

# Node environment (development | production)
NODE_ENV=development

# Logging level (debug | info | warn | error)
LOG_LEVEL=info

# Venice AI SDK (NPC dialogue, narrator)
VENICE_API_KEY=
VENICE_MODEL=llama-3.3-70b
VENICE_TIMEOUT=5000

# Fish Audio TTS (NPC/narrator voice synthesis)
FISH_AUDIO_API_KEY=

# CORS origins (comma-separated, e.g. https://fracture.georgelarson.me)
CORS_ORIGINS=
