{
  "compilerOptions": {
    "lib": ["es2023"],
    "module": "node16",
    "target": "es2022",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node16",
    "allowJs": true,
    "outDir": "../dist",
    "removeComments": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noImplicitThis": false,
    "baseUrl": "./",
    "rootDirs": [
      "./ts",
      "../shared/ts"
    ]
  },
  "include": [
    "./ts/**/*.ts",
    "../shared/ts/gametypes.ts"
  ],
  "exclude": [
    "./node_modules",
    "./ts/__tests__"
  ]
}
