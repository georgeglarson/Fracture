{
  "compilerOptions": {
    "target": "es5",
    "module": "commonjs",
    "lib": ["es2015", "dom"],
    "allowJs": true,
    "checkJs": true,
    "sourceMap": true,
    "outDir": "../dist/client",
    "removeComments": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noImplicitThis": false,
    "types": ["node", "jquery"],
    "rootDirs": [
      "./ts",
      "../shared/ts"
    ],
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "./ts/**/*.ts",
    "../shared/ts/gametypes.ts"
  ],
  "exclude": [
    "./node_modules",
    "./client/ts/lib",
    "./client/ts/lib/underscore.min.js",
    "./ts/__tests__",
    "./ts/**/*.test.ts"
  ]
}
